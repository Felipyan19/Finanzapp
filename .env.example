# App Configuration
APP_NAME=FinanzApp API
APP_VERSION=1.0.0
DEBUG=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=5050
API_PREFIX=/api/v1

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=finanzapp
DB_USER=postgres
DB_PASSWORD=postgres

# CORS Configuration
CORS_ORIGINS=*

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10

# JWT Authentication (REQUIRED in production — use a long random string)
SECRET_KEY=changeme-use-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
